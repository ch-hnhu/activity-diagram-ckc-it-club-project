    { "id": "f3", "type": "action", "lane": "system", "text": "Xóa phản hồi", "data": [ { "table": "EventFeedback", "access": "write" } ] },

    { "id": "g1", "type": "action", "lane": "actor", "text": "Tải lên/sắp xếp/xóa\nảnh thư viện sự kiện" },
