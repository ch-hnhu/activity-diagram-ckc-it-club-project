    { "from": "d2", "to": "e1", "label": "Xem chi tiết &\nđiểm danh" },
    { "from": "e1", "to": "d4" },
    { "from": "d4", "to": "e2", "label": "Quét QR" },
    { "from": "d4", "to": "e3", "label": "Thủ công" },
    { "from": "e2", "to": "d5" },
    { "from": "e3", "to": "d5" },
    { "from": "d5", "to": "e5", "label": "Đã đăng ký,\nchưa điểm danh" },
    { "from": "d5", "to": "e4", "label": "Không hợp lệ" },
    { "from": "e4", "to": "e1" },
    { "from": "e5", "to": "n10" },

    { "from": "d2", "to": "f1", "label": "Kiểm duyệt\nphản hồi" },
