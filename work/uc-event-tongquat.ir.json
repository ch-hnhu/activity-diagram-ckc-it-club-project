    { "id": "g3", "type": "action", "lane": "system", "text": "Cập nhật thư viện\nảnh sự kiện", "data": [ { "table": "EventImage", "access": "write" } ] },

    { "id": "n10", "type": "action", "lane": "system", "text": "Hiển thị thông báo\nthực hiện thành công" },
