    { "id": "d5", "type": "decision", "lane": "system" },
    { "id": "e4", "type": "action", "lane": "system", "text": "Thông báo chưa đăng ký\nhoặc đã điểm danh" },
    { "id": "e5", "type": "action", "lane": "system", "text": "Cập nhật trạng thái\nđiểm danh", "data": [ { "table": "EventAttendance", "access": "write" } ] },

    { "id": "f1", "type": "action", "lane": "actor", "text": "Xem danh sách phản hồi,\nđánh giá của người tham dự" },
