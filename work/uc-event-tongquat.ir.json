    { "from": "f2", "to": "f3" },
    { "from": "f3", "to": "n10" },

    { "from": "d2", "to": "g1", "label": "Quản lý\nthư viện ảnh" },
    { "from": "g1", "to": "d6" },
    { "from": "d6", "to": "g3", "label": "Hợp lệ\n(≤5MB)" },
    { "from": "d6", "to": "g2", "label": "Vượt\ndung lượng" },
    { "from": "g2", "to": "g1" },
    { "from": "g3", "to": "n10" },

    { "from": "n10", "to": "d7" },
    { "from": "d7", "to": "n3", "label": "Tiếp tục\nthao tác khác" },
